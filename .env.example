# APP_URL: Optional URL where this app is hosted (for self-referential links).
APP_URL="http://localhost:3000"

# Supabase (publishable values only — safe for the browser). Copy to .env.local and fill in
# from your Supabase project settings → API.
# Also add this site URL under Authentication → URL Configuration → Redirect URLs
# (e.g. http://localhost:3000 and your production origin) for magic-link sign-in.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# After pulling Phase 2, apply supabase/migrations/20260713120000_user_study_sync.sql
# in the Supabase SQL editor (enables RLS on user_notes + user_explored).
